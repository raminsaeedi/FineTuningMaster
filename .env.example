# ── HuggingFace ──────────────────────────────────────────────
# Token for downloading gated models (e.g. Llama, Mistral).
# Not required for Qwen models, but recommended to avoid rate limits.
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Model cache (optional) ───────────────────────────────────
# Override where HuggingFace stores downloaded model weights.
# Default: ~/.cache/huggingface/hub
# TRANSFORMERS_CACHE=/path/to/model/cache

# ── CUDA / GPU (optional) ────────────────────────────────────
# Limit visible GPUs if running on a multi-GPU machine.
# CUDA_VISIBLE_DEVICES=0
