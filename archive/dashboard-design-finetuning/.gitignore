# ============================================================
# .gitignore for dashboard-design-finetuning
# ============================================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Model weights (too large for git – use Git LFS or HuggingFace Hub)
outputs/models/
*.bin
*.safetensors
*.pt
*.pth

# Logs
outputs/logs/
*.log

# Predictions / results (optional – commit if you want to track experiments)
outputs/predictions/

# HuggingFace cache
.cache/
~/.cache/huggingface/

# Data (raw data may be large – keep processed small examples)
data/raw/
# Keep data/examples/ and data/processed/ in git (they are small)

# OS
.DS_Store
Thumbs.db
desktop.ini

# VS Code
.vscode/
*.code-workspace

# Environment variables (never commit secrets)
.env
*.env
