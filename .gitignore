# ── Secrets ──────────────────────────────────────────────────
.env

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Data ─────────────────────────────────────────────────────
# Processed splits are regeneratable via `python scripts/build_data.py`.
data/processed/
data/index/
# RAG chunks are regeneratable via `python scripts/build_kb.py` (guidelines/ stays tracked).
data/knowledge_base/chunks.jsonl
data/knowledge_base/index/

# ── Experiment outputs & model weights (large; not versioned) ─
# NOTE: ignore any 'models/' weights directory, but keep the source package
# src/models/ (the import-safe HF wrapper) tracked — the negation re-includes it.
outputs/
models/
!src/models/

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Claude worktrees (AI-generated temporary workspaces) ─────
.claude/worktrees/

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
